// Solennix — Secrets template (committed)
//
// Copy this file to Secrets.xcconfig and fill in real values.
// Secrets.xcconfig is gitignored.
//
// NOTE on URL values: xcconfig treats `//` as a comment. For values
// containing `//` (like Sentry DSN), use this escape: $()https://...

// RevenueCat public SDK key for the Apple app.
// Get from: https://app.revenuecat.com → Apps & providers → API keys
// Production format: appl_xxxxxxxxxxxxxxxx
// Test format:       test_xxxxxxxxxxxxxxxx
REVENUECAT_PUBLIC_API_KEY =

// Sentry DSN for iOS. Format: https://PUBLIC_KEY@ORG.ingest.sentry.io/PROJECT_ID
// Remember the $() escape when filling in: SENTRY_DSN = $()https://xxx@oyyy.ingest.sentry.io/zzz
SENTRY_DSN =

// Sentry environment. Use `development` for local builds,
// `production` for Release/TestFlight/App Store builds.
SENTRY_ENVIRONMENT = development
